{
  "name": "@ecocitizenz/ecz-id-mcp-verifier",
  "version": "0.7.1",
  "description": "ECZ-ID MCP Verifier(TM). Local-first, privacy-first verifier for MCP servers, agents, APIs, packages, repos, container images, and ECZ-IDs. Reports only. Does not write truth, activate proof, or mark BOUND.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ecz-id-mcp-verifier": "dist/cli.js",
    "ecz-mcp-verify": "dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE.md",
    "docs/ROLE_SPLIT.md",
    "docs/PRIVACY.md",
    "examples"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "scan:public": "node scripts/scan-public.mjs",
    "harness:action": "node scripts/action-harness.mjs",
    "release:check": "npm run typecheck && npm run test && npm run build && npm run scan:public",
    "pack:inspect": "npm pack --dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "ecz-id",
    "mcp",
    "verifier",
    "resolver",
    "agent-trust",
    "machine-readable",
    "trustops",
    "action-envelope",
    "local-first",
    "privacy-first"
  ],
  "author": "EcoCitizenZ",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://developers.ecocitizenz.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ecocitizenz/ecz-id-mcp-verifier.git"
  },
  "bugs": {
    "url": "https://github.com/Ecocitizenz/ecz-id-mcp-verifier/issues"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=18"
  }
}
