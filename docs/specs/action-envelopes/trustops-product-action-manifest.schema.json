{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developers.ecocitizenz.com/schemas/action-envelopes/trustops-product-action-manifest.schema.json",
  "title": "TrustOps Product/Action Manifest (Acquisition Mandate)",
  "description": "Machine-readable commercial manifest. Route-only. Does NOT create checkout, create entitlement, activate proof, imply certification, or imply platform endorsement. Payment is not proof.",
  "type": "object",
  "required": ["manifest_type", "version", "generated_boundary", "products", "rejected", "global_boundaries"],
  "additionalProperties": true,
  "properties": {
    "manifest_type": { "const": "ecz.trustops_product_action_manifest" },
    "version": { "type": "string" },
    "generated_boundary": {
      "type": "string",
      "description": "Static manifest. Does not create checkout, entitlement, or proof."
    },
    "rejected": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Concepts explicitly not offered (e.g. mcp_passport)."
    },
    "global_boundaries": {
      "type": "object",
      "required": ["not_safety_certification", "local_policy_decides", "marketplace_native_entitlement"],
      "properties": {
        "not_safety_certification": { "const": true },
        "local_policy_decides": { "const": true },
        "marketplace_native_entitlement": { "const": "forbidden" }
      }
    },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "product_name",
          "product_status",
          "price",
          "route",
          "proof_boundary",
          "purchase_boundary",
          "backend_truth_boundary",
          "resolver_projection_boundary",
          "not_safety_certification",
          "local_policy_decides"
        ],
        "properties": {
          "product_name": { "type": "string" },
          "product_status": {
            "type": "string",
            "enum": ["canonical", "off_ssot_provisional", "deferred", "rejected"]
          },
          "price": { "type": "string" },
          "route": { "type": "string" },
          "required_parent_passport": { "type": ["string", "null"] },
          "proof_boundary": { "type": "string" },
          "purchase_boundary": { "type": "string" },
          "backend_truth_boundary": { "type": "string" },
          "resolver_projection_boundary": { "type": "string" },
          "not_safety_certification": { "const": true },
          "local_policy_decides": { "const": true }
        }
      }
    }
  }
}
